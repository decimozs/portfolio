{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    }
  },
  "additionalProperties": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string"
      },
      "title": {
        "type": "string"
      },
      "description": {
        "type": "string"
      },
      "links": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "label": {
              "type": "string"
            },
            "href": {
              "type": "string",
              "format": "uri"
            }
          },
          "required": ["label", "href"]
        }
      },
      "category": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "date": {
        "type": "string"
      }
    },
    "required": ["id", "title", "description", "links", "category", "date"]
  }
}
