---
import { getCollection } from "astro:content";
import { formatDate } from "@/lib/date";
import { getReadingTime } from "@/lib/reading-time";
import Layout from "../layouts/Layout.astro";

const title = "Blog";
const description = "Notes and essays by Marlon Martin.";

const blogCollection = await getCollection("blog");
const sortedPosts = [...blogCollection].sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<Layout title={title} description={description}>
    <div class="mt-4 xl:mt-0 flex flex-col gap-14 w-full">
        {
            sortedPosts.map((post) => {
                const readingTime = getReadingTime(post.body);

                return (
                <article class="flex flex-col gap-4">
                    <div class="flex flex-row justify-between gap-6">
                        <a href={`/blog/${post.id}`} class="-mb-2 w-fit underline-animate">
                            {post.data.title}
                        </a>
                        <p class="hidden xl:block text-sm shrink-0">
                            {formatDate(post.data.date)}
                        </p>
                    </div>
                    <p>{post.data.description}</p>
                    <p class="xl:hidden text-sm text-muted-foreground">
                        {formatDate(post.data.date)}
                    </p>
                    <p class="text-sm text-muted-foreground">
                        {readingTime}
                    </p>
                </article>
                );
            })
        }
    </div>
</Layout>
