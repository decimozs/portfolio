---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const notebooksCollection = await getCollection("notebooks");
const notebookItems = notebooksCollection.map((entry) => entry.data);
const recentNotebooks = [...notebookItems]
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, 4);

const worksCollection = await getCollection("works");
const works = [...worksCollection.map((entry) => entry.data)].sort(
  (a, b) => b.date.getTime() - a.date.getTime(),
);
---

<Layout>
    <p class="mt-4 lg:mt-0">
    Based in Manila, I engineer AI systems that work — not just in theory, but in the real world, I build and deploy ai solutions that make everyday life measurably easier.
    </p>
    <p class="mt-10 mb-4">
      A selection of projects I've recently shipped
    </p>
    <div class="mb-10 grid grid-cols-1 gap-4 lg:grid-cols-2">
      {works.slice(0, 4).map((work) => (
      <a class="px-4 py-2 bg-accent" href={work.link} 
            target="_blank"
            rel="noopener noreferrer"
        >
          <p>{work.title}</p>
          <p class="text-sm text-muted-foreground mt-2 line-clamp-2">{work.description}</p>
        </a>
        ))}
    </div>
    <p class="mt-10 mb-4">
      Recent notebooks and experiments I've been running
    </p>
    <div class="mb-10 grid grid-cols-1 gap-4 lg:grid-cols-2">
      {recentNotebooks.map((notebook) => (
      <a class="px-4 py-2 bg-accent" href={notebook.links[0]?.href} 
            target="_blank"
            rel="noopener noreferrer"
        >
          <p>{notebook.title}</p>
          <p class="text-sm text-muted-foreground mt-2 line-clamp-2">{notebook.description}</p>
        </a>
        ))}
    </div>
    <p>
        To learn more about my background and professional experience, you can
        view my{" "}
        <a
            href="/resume.pdf"
            class="italic text-muted-foreground hover:text-black underline-animate"
            target="_blank"
            rel="noopener noreferrer"
            id="resume-link"
        >
            resume
        </a>
        . Additionally, to see my work in action, feel free to browse my{" "}
        <a
            href="/works"
            class="italic text-muted-foreground hover:text-black underline-animate"
        >
            works
        </a>
        , explore my contributions on{" "}
        <a
            href="https://github.com/decimozs"
            class="italic text-muted-foreground hover:text-black underline-animate"
            target="_blank"
            rel="noopener noreferrer"
            id="github-profile-link"
        >
            @github/decimozs
        </a>
        , or connect with me on{" "}
        <a
            href="https://www.linkedin.com/in/decimomartin/"
            class="italic text-muted-foreground hover:text-black underline-animate"
            target="_blank"
            rel="noopener noreferrer"
            id="linkedin-profile-link"
        >
            @linkedin/decimomartin
        </a>
        .
    </p>
</Layout>

<script>
    import { track } from "@/lib/tracking";

    document
        .getElementById("resume-link")
        ?.addEventListener("click", function () {
            track("resume_clicked", { source: "about" });
        });
    document
        .getElementById("github-profile-link")
        ?.addEventListener("click", function () {
            track("github_profile_clicked", {
                source: "about",
            });
        });
    document
        .getElementById("linkedin-profile-link")
        ?.addEventListener("click", function () {
            track("linkedin_profile_clicked", {
                source: "about",
            });
        });
</script>
