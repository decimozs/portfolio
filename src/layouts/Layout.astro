---
import { ClientRouter } from "astro:transitions";
import Hamburger from "../components/hamburger";
import Header from "../components/header.astro";
import MainLayout from "../components/main-layout.astro";
import Nav from "../components/nav.astro";
import PostHog from "../components/posthog.astro";
import SEO from "../components/SEO.astro";
import SmoothScroll from "../components/smooth-scroll";
import { jsonLd } from "../lib/seo";
import "../styles/globals.css";

interface Props {
  title?: string;
  description?: string;
  fullHeight?: boolean;
  agentShell?: boolean;
}

const {
  title,
  description,
  fullHeight = false,
  agentShell = false,
} = Astro.props;
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<!doctype html>
<html lang="en" class="h-full">
    <head>
        <ClientRouter />
        <SEO title={title} description={description} />
        <PostHog />
        <link
            rel="preload"
            href="/font/OverusedGrotesk-Book.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <style is:global>
            @font-face {
                font-family: "OverusedGrotesk";
                src: url("/font/OverusedGrotesk-Book.woff2") format("woff2");
                font-weight: normal;
                font-style: normal;
                font-display: swap;
            }
            :root {
                --font-overused-grotesk: "OverusedGrotesk", sans-serif;
            }
            html {
                font-family: var(--font-overused-grotesk);
            }
        </style>
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    </head>
    <body class="antialiased bg-white text-black">
        {pathname === "/" && (
            <div id="landing-loader" aria-hidden="true">
                <p>
                    <span class="landing-loader-name">Marlon Martin</span>
                    <span class="landing-loader-title">Portfolio</span>
                </p>
            </div>
        )}
        <!-- SmoothScroll: returns null, client:only is correct here -->
        <SmoothScroll client:only="react" />
        {!agentShell && <Hamburger client:only="react" pathname={pathname} />}
        <div id="landing-content">
            <MainLayout fullHeight={fullHeight} agentShell={agentShell}>
                {!agentShell && (
                    <div class={`flex flex-col gap-8 xl:sticky xl:top-8 xl:self-start ${fullHeight ? "shrink-0" : ""}`}>
                        <Header pathname={pathname} compact={fullHeight} />
                        <Nav pathname={pathname} />
                        <p class='hidden lg:block text-sm opacity-50 text-muted-foreground hover:text-black hover:opacity-100'>© 2026 Marlon Martin</p>
                    </div>
                )}
                <div class={`w-full ${fullHeight ? "h-full min-h-0 flex flex-col" : ""} ${agentShell ? "max-w-3xl mx-auto" : ""}`}>
                    <slot />
                </div>
            </MainLayout>
        </div>
        <script is:inline>
            (() => {
                const removeLandingLoader = () => {
                    document.getElementById("landing-loader")?.remove();
                    document.documentElement.classList.remove("landing-content-pending");
                    document.documentElement.classList.add("landing-content-visible");
                };

                if (!window.__landingLoaderWired) {
                    window.__landingLoaderWired = true;
                    document.addEventListener("astro:after-swap", removeLandingLoader);
                }

                const loader = document.getElementById("landing-loader");
                if (!loader) {
                    window.__landingLoaderBooted = true;
                    document.documentElement.classList.add("landing-content-visible");
                    return;
                }

                if (window.__landingLoaderBooted) {
                    loader.remove();
                    document.documentElement.classList.add("landing-content-visible");
                    return;
                }

                window.__landingLoaderBooted = true;
                document.documentElement.classList.add("landing-content-pending");
                requestAnimationFrame(() => loader.classList.add("is-running"));
                window.setTimeout(() => loader.classList.add("is-done"), 2000);
                window.setTimeout(() => loader.remove(), 2450);
                window.setTimeout(() => {
                    document.documentElement.classList.remove("landing-content-pending");
                    document.documentElement.classList.add("landing-content-visible");
                }, 2450);
            })();
        </script>
        <script is:inline>
            (() => {
                if (window.__routeScrollWired) {
                    return;
                }

                window.__routeScrollWired = true;
                document.addEventListener("astro:after-swap", () => {
                    window.scrollTo({ left: 0, top: 0, behavior: "instant" });
                    window.dispatchEvent(new Event("portfolio:scroll-top"));
                });
            })();
        </script>
    </body>
</html>
